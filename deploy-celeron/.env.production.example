# Production env for the Celeron / 4GB deployment PC.
# Copy to .env.production (or .env, whichever app.core.config.py / next.config.ts load)
# on the target machine and fill in real values. Never commit the filled-in file.

# ── Database ───────────────────────────────────────────────────────────────
# MongoDB Atlas connection string (free tier). Create a cluster at
# https://cloud.mongodb.com, add a DB user, and allow-list this PC's public IP
# (or 0.0.0.0/0 only if you understand the exposure trade-off).
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster-host>/?retryWrites=true&w=majority
MONGODB_DB=abuelos

# ── Authentication ─────────────────────────────────────────────────────────
# Generate a real secret, e.g.: openssl rand -hex 32
JWT_SECRET=change-me-to-a-real-random-secret

# ── URLs (single-machine access only, so localhost is correct) ────────────
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Email (SMTP) — required for company registration confirmation emails ──
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@yourcompany.com
SMTP_PASSWORD=your-smtp-password
