# Copy this file to .env and fill in values before running the project

# ── Authentication ────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-key-change-in-production

# ── URLs ─────────────────────────────────────────────────────────────────────
# URL of the frontend (used by backend for CORS)
FRONTEND_URL=http://localhost:3000

# URL of the backend API (used by frontend)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Required for company registration confirmation emails (Phase 1)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@yourcompany.com
SMTP_PASSWORD=your-smtp-password
